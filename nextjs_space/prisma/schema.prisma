// Prisma schema for CashFlowIQ

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  password             String?
  businessName         String?
  businessType         String?
  emailVerified        DateTime?
  image                String?
  subscriptionTier     String    @default("free")
  accounts             Account[]
  sessions             Session[]
  transactions         Transaction[]
  forecasts            Forecast[]
  linkedAccounts       LinkedAccount[]
  stripeCustomer       StripeCustomer?
  teamMemberships      TeamMember[]
  ownedTeams           Team[]
  apiKeys              ApiKey[]
  webhooks             Webhook[]
  reportExports        ReportExport[]
  adminRole            AdminRole?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  lastLoginAt          DateTime?

  @@index([email])
}

model AdminRole {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role               String    @default("admin") // "admin", "super_admin"
  permissions        String[]  @default(["view_analytics", "manage_users", "export_data"]) // granular permissions
  grantedBy          String?   // userId of admin who granted this role
  grantedAt          DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([role])
}

model StripeCustomer {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId   String    @unique
  email              String
  subscriptions      StripeSubscription[]
  invoices           StripeInvoice[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
}

model StripeSubscription {
  id                 String    @id @default(cuid())
  stripeCustomerId   String
  stripeCustomer     StripeCustomer @relation(fields: [stripeCustomerId], references: [id], onDelete: Cascade)
  subscriptionId     String    @unique
  priceId            String
  productId          String
  tier               String    // "solo", "pro", "team"
  status             String    // "active", "past_due", "canceled", etc
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?
  metadata           String?   @db.Text // JSON string for additional data
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([stripeCustomerId])
  @@index([status])
}

model StripeInvoice {
  id                 String    @id @default(cuid())
  stripeCustomerId   String
  stripeCustomer     StripeCustomer @relation(fields: [stripeCustomerId], references: [id], onDelete: Cascade)
  invoiceId          String    @unique
  number             String?
  amount             Int       // Amount in cents
  currency           String
  status             String    // "draft", "open", "paid", "void", "uncollectible"
  paidAt             DateTime?
  dueDate            DateTime?
  invoiceUrl         String?   @db.Text
  pdfUrl             String?   @db.Text
  metadata           String?   @db.Text // JSON string for additional data
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([stripeCustomerId])
  @@index([status])
}

model Transaction {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                  String
  amount                Decimal  @db.Decimal(10, 2)
  category              String
  date                  DateTime
  description           String?
  plaidTransactionId    String?
  linkedAccountId       String?
  source                String   @default("manual") // "manual" or "plaid"
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([type])
  @@index([category])
  @@index([plaidTransactionId])
}

model Forecast {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date               DateTime
  projectedCashFlow  Decimal  @db.Decimal(12, 2)
  confidence         Int?
  // Advanced forecasting fields (Phase 3)
  seasonalityFactor  Decimal? @db.Decimal(5, 4) // e.g., 1.2 = 20% above baseline
  trendFactor        Decimal? @db.Decimal(5, 4)
  anomalyScore       Decimal? @db.Decimal(5, 4) // 0-1: probability of anomaly
  isAnomaly          Boolean  @default(false)
  forecastMethod     String   @default("linear") // "linear", "arima", "neural_net"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

model LinkedAccount {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plaidItemId           String    @unique
  plaidAccessToken      String    @db.Text
  plaidInstitutionId    String?
  institutionName       String?
  accountName           String?
  accountType           String?
  accountSubtype        String?
  accountMask           String?
  currentBalance        Decimal?  @db.Decimal(12, 2)
  isActive              Boolean   @default(true)
  lastSyncedAt          DateTime?
  syncStatus            String    @default("pending") // pending, syncing, success, error
  syncError             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  syncCursors           SyncCursor[]

  @@index([userId])
  @@index([plaidItemId])
}

model SyncCursor {
  id                  String    @id @default(cuid())
  linkedAccountId     String
  linkedAccount       LinkedAccount @relation(fields: [linkedAccountId], references: [id], onDelete: Cascade)
  cursor              String    @db.Text
  lastSyncedAt        DateTime  @default(now())

  @@unique([linkedAccountId])
  @@index([linkedAccountId])
}

// ===== PHASE 3: Multi-account, Team, API, Report Export =====

model ReportExport {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId             String?
  team               Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  reportType         String    // "cash_flow", "category_breakdown", "monthly_comparison", "full_report"
  fileFormat         String    // "pdf", "xlsx"
  fileName           String
  filePath           String?   @db.Text // cloud storage path
  fileSize           Int?      // in bytes
  dateRangeStart     DateTime?
  dateRangeEnd       DateTime?
  status             String    @default("pending") // "pending", "generating", "completed", "failed"
  errorMessage       String?   @db.Text
  createdAt          DateTime  @default(now())
  completedAt        DateTime?
  expiresAt          DateTime? // auto-delete after 30 days
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([status])
  @@index([createdAt])
}

model Team {
  id                 String    @id @default(cuid())
  name               String
  ownerId            String    // Primary user who owns/created the team
  owner              User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  slug               String    @unique
  description        String?   @db.Text
  maxMembers         Int       @default(5) // limited by subscription tier
  members            TeamMember[]
  invitations        TeamInvitation[]
  sharedDashboards   SharedDashboard[]
  reportExports      ReportExport[]
  auditLogs          AuditLog[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([ownerId])
  @@index([slug])
}

model TeamMember {
  id                 String    @id @default(cuid())
  teamId             String
  team               Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role               String    @default("member") // "owner", "manager", "member", "viewer" (Phase 4)
  joinedAt           DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model TeamInvitation {
  id                 String    @id @default(cuid())
  teamId             String
  team               Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  email              String
  role               String    @default("member") // default role for invited user
  invitedBy          String    // userId of person who sent invite
  status             String    @default("pending") // "pending", "accepted", "rejected"
  expiresAt          DateTime
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([teamId, email])
  @@index([teamId])
  @@index([email])
  @@index([status])
}

model ApiKey {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyHash            String    @unique // hashed version of actual key
  name               String
  description        String?   @db.Text
  lastUsedAt         DateTime?
  expiresAt          DateTime?
  isActive           Boolean   @default(true)
  rateLimit          Int       @default(1000) // requests per hour
  requestCount       Int       @default(0) // total requests made with this key
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([keyHash])
}

model Webhook {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  url                String
  events             String[]  // e.g., ["transaction.created", "forecast.updated"]
  secret             String    // for HMAC signature verification
  description        String?   @db.Text
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deliveries         WebhookDelivery[]

  @@index([userId])
  @@index([url])
}

model WebhookDelivery {
  id                 String    @id @default(cuid())
  webhookId          String
  webhook            Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventType          String    // e.g., "transaction.created"
  payload            String    @db.Text
  statusCode         Int?
  success            Boolean   @default(false)
  attempt            Int       @default(1)
  nextRetryAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([webhookId])
  @@index([eventType])
  @@index([createdAt])
}

// ===== PHASE 4: Audit Logging & Shared Dashboards =====

model AuditLog {
  id                 String    @id @default(cuid())
  teamId             String
  team               Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId             String    // Who made the change
  action             String    // "create", "update", "delete", "export", "invite"
  entityType         String    // "transaction", "forecast", "user", "team", etc
  entityId           String?
  changes            String?   @db.Text // JSON of before/after values
  ipAddress          String?
  userAgent          String?   @db.Text
  createdAt          DateTime  @default(now())

  @@index([teamId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model SharedDashboard {
  id                 String    @id @default(cuid())
  teamId             String
  team               Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name               String
  description        String?   @db.Text
  isPublic           Boolean   @default(false)
  shareToken         String?   @unique // for public sharing
  widgets            String?   @db.Text // JSON array of widget configs
  layout             String?   @db.Text // JSON of grid layout
  createdBy          String
  updatedAt          DateTime  @updatedAt
  createdAt          DateTime  @default(now())

  @@index([teamId])
  @@index([shareToken])
}

// ===== ADMIN DASHBOARD: Analytics & Monitoring =====

model ApiUsageLog {
  id                 String    @id @default(cuid())
  userId             String    // optional, if by authenticated user
  tier               String    // "free", "solo", "pro", "team"
  endpoint           String
  method             String    // GET, POST, PUT, DELETE
  statusCode         Int
  responseTimeMs     Int?
  ipAddress          String?
  createdAt          DateTime  @default(now())

  @@index([userId])
  @@index([tier])
  @@index([createdAt])
}

model SystemHealthMetric {
  id                 String    @id @default(cuid())
  timestamp          DateTime  @default(now())
  cpuUsage           Decimal?  @db.Decimal(5, 2) // percentage
  memoryUsage        Decimal?  @db.Decimal(5, 2) // percentage
  dbConnections      Int?
  avgResponseTimeMs  Int?
  errorCount         Int       @default(0)
  requestCount       Int       @default(0)
  status             String    @default("healthy") // "healthy", "degraded", "down"
  notes              String?   @db.Text

  @@index([timestamp])
  @@index([status])
}

model PlaidSyncMetric {
  id                 String    @id @default(cuid())
  linkedAccountId    String?
  userId             String?
  syncStatus         String    // "success", "failed"
  totalTransactions  Int       @default(0)
  newTransactions    Int       @default(0)
  updatedTransactions Int      @default(0)
  errorMessage       String?   @db.Text
  syncDurationMs     Int?
  createdAt          DateTime  @default(now())

  @@index([linkedAccountId])
  @@index([userId])
  @@index([syncStatus])
  @@index([createdAt])
}
